# Copier ce fichier en .env et remplir les valeurs

# Django
DJANGO_SECRET_KEY=changeme-generate-a-long-random-string
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com
FRONTEND_ORIGIN=http://votre-domaine.com

# PostgreSQL
DB_NAME=syndic_db
